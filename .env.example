# Add environment variables to .env.example
@"
# Client Configuration
VITE_CLIENT=osu

# API Configuration
VITE_API_URL=/api

# Backend URL (for development)
VITE_API_BASE_URL=https://cpd.cms.oeb.gov.et

# Mock Data (set to false for real backend)
VITE_USE_MOCK=false

# Development credentials
VITE_DEV_USERNAME=OSU985240
VITE_DEV_PASSWORD=2030
"@ | Out-File -FilePath .env.example -Encoding utf8